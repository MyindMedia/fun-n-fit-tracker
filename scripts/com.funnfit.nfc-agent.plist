<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.funnfit.nfc-agent</string>
  <key>ProgramArguments</key>
  <array>
    <string>/opt/homebrew/bin/node</string>
    <string>scripts/nfc-agent.mjs</string>
  </array>
  <key>WorkingDirectory</key>
  <string>/Users/myindsound/Myind Media Dev/-fun-n-fit-tracker-main</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>ThrottleInterval</key>
  <integer>10</integer>
  <key>StandardOutPath</key>
  <string>/Users/myindsound/Library/Logs/fnf-nfc-agent.log</string>
  <key>StandardErrorPath</key>
  <string>/Users/myindsound/Library/Logs/fnf-nfc-agent.log</string>
</dict>
</plist>
